## 8. Database Schema

Full Prisma schema for all eight models.

```prisma
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────

enum Role {
  PROVIDER
  CUSTOMER
}

enum BookingStatus {
  PENDING
  ACCEPTED
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum TransactionType {
  PAYMENT
  CREDIT
  WITHDRAWAL
  REFUND
  TOPUP
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ScoreTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ─── MODELS ──────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  phone              String    @unique
  name               String
  role               Role
  photoUrl           String?
  state              String
  lga                String
  nin                String?
  squadAccountNo     String?
  squadAccountRef    String?
  squadCustomerId    String?
  isVerified         Boolean   @default(false)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  provider           Provider?
  customerBookings   Booking[]       @relation("CustomerBookings")
  transactions       Transaction[]
  notifications      Notification[]
  reviews            Review[]        @relation("CustomerReviews")
}

model Provider {
  id              String     @id @default(uuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  tradeCategory   String
  bio             String     @db.VarChar(300)
  yearsExperience Int        @default(0)
  priceMin        Decimal    @default(0) @db.Decimal(12, 2)
  priceMax        Decimal    @default(0) @db.Decimal(12, 2)

  latitude        Float?
  longitude       Float?

  avgRating       Float      @default(0.0)
  totalJobs       Int        @default(0)
  totalEarned     Decimal    @default(0) @db.Decimal(14, 2)
  completionRate  Float      @default(0.0)
  responseTimeAvg Int        @default(0) // minutes

  isAvailable     Boolean    @default(true)
  creditScore     Float      @default(0)
  scoreTier       ScoreTier  @default(BRONZE)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  services        Service[]
  bookings        Booking[]  @relation("ProviderBookings")
  reviews         Review[]   @relation("ProviderReviews")
  creditScores    CreditScore[]
}

model Service {
  id            String    @id @default(uuid())
  providerId    String
  provider      Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  price         Decimal   @db.Decimal(12, 2)
  durationMins  Int
  category      String
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  bookings      Booking[]
}

model Booking {
  id              String        @id @default(uuid())
  customerId      String
  customer        User          @relation("CustomerBookings", fields: [customerId], references: [id])
  providerId      String
  provider        Provider      @relation("ProviderBookings", fields: [providerId], references: [id])
  serviceId       String
  service         Service       @relation(fields: [serviceId], references: [id])

  status          BookingStatus @default(PENDING)
  scheduledAt     DateTime
  jobAddress      String
  description     String
  amount          Decimal       @db.Decimal(12, 2)
  platformFee     Decimal       @db.Decimal(12, 2)
  totalCharged    Decimal       @db.Decimal(12, 2)

  squadEscrowRef  String?
  squadPaymentRef String?

  acceptedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  transactions    Transaction[]
  review          Review?
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  bookingId     String?
  booking       Booking?          @relation(fields: [bookingId], references: [id])

  type          TransactionType
  amount        Decimal           @db.Decimal(12, 2)
  squadRef      String            @unique
  squadEvent    String
  status        TransactionStatus @default(PENDING)
  description   String
  metadata      Json?             // raw Squad webhook payload

  createdAt     DateTime          @default(now())
}

model Review {
  id          String    @id @default(uuid())
  bookingId   String    @unique
  booking     Booking   @relation(fields: [bookingId], references: [id])
  customerId  String
  customer    User      @relation("CustomerReviews", fields: [customerId], references: [id])
  providerId  String
  provider    Provider  @relation("ProviderReviews", fields: [providerId], references: [id])

  rating      Int       // 1–5
  comment     String?

  createdAt   DateTime  @default(now())
}

model CreditScore {
  id             String     @id @default(uuid())
  providerId     String
  provider       Provider   @relation(fields: [providerId], references: [id])

  score          Float      // 0–100
  jobsScore      Float      // sub-score: completed bookings (40% weight)
  earningsScore  Float      // sub-score: total earned (30% weight)
  ratingScore    Float      // sub-score: avg rating (20% weight)
  tenureScore    Float      // sub-score: account age in days (10% weight)
  tier           ScoreTier

  computedAt     DateTime   @default(now())
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  type        String
  title       String
  body        String
  isRead      Boolean   @default(false)
  relatedId   String?   // bookingId or transactionId for deep-linking

  createdAt   DateTime  @default(now())
}
```

### Key Schema Decisions

**Decimal for all money fields.** Never use `Float` for money. `Decimal` in Prisma maps to PostgreSQL's `NUMERIC` type, which avoids floating point rounding errors that would cause pence/kobo discrepancies.

**`metadata Json?` on Transaction.** The raw Squad webhook payload is stored so it can be replayed or debugged if something goes wrong with the webhook processing. This is critical for financial reconciliation.

**`@unique` on `Review.bookingId`.** Enforced at the database level — one review per booking, not just at the application level. Cannot be bypassed by a race condition.

**`onDelete: Cascade` on Provider → User.** If a user account is deleted, their provider profile is automatically removed too. Prevents orphaned provider records.

