generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  ESCROW_CHARGE
  ESCROW_RELEASE
  WITHDRAWAL
  REFUND
  WALLET_CREDIT
  WALLET_DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ReviewType {
  CUSTOMER_TO_PROVIDER
  PROVIDER_TO_CUSTOMER
}

enum ScoreTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model User {
  id                String         @id @default(cuid())
  phone             String         @unique
  email             String?        @unique
  firstName         String
  lastName          String
  role              UserRole
  isVerified        Boolean        @default(false)
  avatarUrl         String?
  city              String?
  state             String?
  country           String         @default("Nigeria")
  squadAccountNo    String?
  squadAccountRef   String?
  tokenVersion      Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  provider          Provider?
  bookingsAsCustomer Booking[]     @relation("CustomerBookings")
  bookingsAsProvider Booking[]     @relation("ProviderBookings")
  transactions      Transaction[]
  reviewsGiven      Review[]       @relation("ReviewsGiven")
  reviewsReceived   Review[]       @relation("ReviewsReceived")
  creditScores      CreditScore[]
}

model Provider {
  id              String      @id @default(cuid())
  userId          String      @unique
  tradeName       String
  bio             String?
  skills          String[]
  yearsExperience Int         @default(0)
  priceFrom       Decimal?    @db.Decimal(12, 2)
  priceTo         Decimal?    @db.Decimal(12, 2)
  availability    String?
  verificationStatus String   @default("pending")
  averageRating   Decimal?    @db.Decimal(3, 2)
  completedJobs   Int         @default(0)
  totalEarnings   Decimal     @default(0) @db.Decimal(14, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  services        Service[]
  reviews         Review[]
  creditScores    CreditScore[]
}

model Service {
  id           String    @id @default(cuid())
  providerId   String
  title        String
  description  String?
  category     String
  price        Decimal   @db.Decimal(14, 2)
  currency     String    @default("NGN")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  provider     Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  bookings     Booking[]
}

model Booking {
  id             String         @id @default(cuid())
  customerId     String
  providerId     String
  serviceId      String
  status         BookingStatus  @default(PENDING)
  amount         Decimal        @db.Decimal(14, 2)
  currency       String         @default("NGN")
  scheduledAt    DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  squadEscrowRef String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer       User           @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  provider       User           @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  reviews        Review[]

  @@index([customerId])
  @@index([providerId])
  @@index([status])
}

model Transaction {
  id           String            @id @default(cuid())
  userId       String
  bookingId    String?
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  amount       Decimal           @db.Decimal(14, 2)
  currency     String            @default("NGN")
  squadRef     String?           @unique
  squadEvent   String?
  metadata     Json?
  rawPayload   Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking      Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingId])
  @@index([type])
  @@index([status])
}

model Review {
  id          String     @id @default(cuid())
  bookingId   String     @unique
  reviewerId  String
  revieweeId  String
  providerId  String?
  rating      Int
  comment     String?
  type        ReviewType
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  booking     Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer    User       @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User       @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  provider    Provider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([reviewerId])
  @@index([revieweeId])
  @@index([providerId])
}

model CreditScore {
  id            String    @id @default(cuid())
  userId        String
  providerId    String?
  score         Int
  tier          ScoreTier
  jobsScore     Int
  earningsScore Int
  ratingScore   Int
  tenureScore   Int
  narrative     String?
  calculatedAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerId])
  @@index([tier])
}